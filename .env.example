# Admin bootstrap (used on first run only — creates admin user in DB)
DARKREEL_ADMIN_USERNAME=admin
DARKREEL_ADMIN_PASSWORD=

# Session persistence (cache master key in sessionStorage — survives page refresh, less secure)
PERSIST_SESSION=false

# User registration via web UI (default: disabled)
ALLOW_REGISTRATION=false

# CLI flags (not env vars):
#   -addr :8080       Listen address
#   -data ./data      Data directory for encrypted files and database
